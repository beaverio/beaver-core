# Environment Configuration for Beaver Core Express API

# Application Settings
NODE_ENV=development
PORT=3000
API_DOMAIN=http://localhost:3000
WEBSITE_DOMAIN=http://localhost:3000

# Database Configuration (local Docker containers)
DATABASE_URL=postgresql://postgres:postgres_password@postgres:5432/beaver_core_db
# Redis Configuration (local Docker container)
REDIS_URL=redis://redis:6379

# SuperTokens Configuration
SUPERTOKENS_CONNECTION_URI=http://supertokens:3567
