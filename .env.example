# Environment Configuration for Beaver Core Express API

# Application Settings
NODE_ENV=development
PORT=3000
API_DOMAIN=http://localhost:3000
WEBSITE_DOMAIN=http://localhost:3000

# Database Configuration (for local development - use container names)
DATABASE_URL=postgresql://postgres:postgres_password@postgres:5432/beaver_db

# Redis Configuration (for local development - use container names)
REDIS_URL=redis://redis:6379

# SuperTokens Configuration
SUPERTOKENS_CONNECTION_URI=http://supertokens:3567
SUPERTOKENS_DASHBOARD_API_KEY=your-dashboard-api-key-here

# Production Notes:
# - Replace DATABASE_URL with your external PostgreSQL connection string
# - Replace REDIS_URL with your external Redis connection string  
# - Generate a secure SUPERTOKENS_DASHBOARD_API_KEY for production
# - Set API_DOMAIN and WEBSITE_DOMAIN to your actual domain
# - Set NODE_ENV=production for production deployments
